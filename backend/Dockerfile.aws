# AWS Lambda公式のPython 3.11イメージを使用
FROM public.ecr.aws/lambda/python:3.11

# 依存関係ファイルをコピー
COPY requirements.txt ${LAMBDA_TASK_ROOT}

# 依存関係をインストール
# --no-cache-dir: イメージサイズ削減
RUN pip install --no-cache-dir -r requirements.txt

# ソースコードをすべてコピー
COPY . ${LAMBDA_TASK_ROOT}

# Lambdaの起動コマンド (Mangumハンドラを指定)
# main.py の中の handler 変数を指す
CMD [ "main.handler" ]